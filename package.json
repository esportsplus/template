{
    "author": "ICJR",
    "dependencies": {
        "@esportsplus/queue": "^0.4.2",
        "@esportsplus/reactivity": "^0.31.2",
        "@esportsplus/typescript": "^0.29.5",
        "@esportsplus/utilities": "^0.28.0"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^4.1.9",
        "jsdom": "^29.1.1",
        "vitest": "^4.1.9"
    },
    "exports": {
        "./compiler": {
            "types": "./build/compiler/index.d.ts",
            "default": "./build/compiler/index.js"
        },
        "./compiler/tsc": {
            "types": "./build/compiler/plugins/tsc.d.ts",
            "default": "./build/compiler/plugins/tsc.js"
        },
        "./compiler/vite": {
            "types": "./build/compiler/plugins/vite.d.ts",
            "default": "./build/compiler/plugins/vite.js"
        },
        ".": {
            "types": "./build/index.d.ts",
            "default": "./build/index.js"
        }
    },
    "main": "./build/index.js",
    "name": "@esportsplus/template",
    "private": false,
    "repository": {
        "type": "git",
        "url": "https://github.com/esportsplus/template"
    },
    "scripts": {
        "bench:run": "vitest bench --config vitest.bench.config.ts",
        "build": "tsc",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "-": "-",
        "prepare": "pnpm build",
        "prepublishOnly": "pnpm build"
    },
    "type": "module",
    "types": "./build/index.d.ts",
    "version": "0.17.6"
}
